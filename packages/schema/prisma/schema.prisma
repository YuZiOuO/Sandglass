// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../generated/zod"
  config   = "./zod-generator.config.json"
}

model Project {
  id String @id @default(uuid())

  uid String

  calendarId String

  tasklistId String
}

enum AttendanceType {
  IN
  OUT
  PAUSE
}

model AttendanceRecord {
  id String @id @default(uuid())

  uid String

  time DateTime

  summary String?

  type AttendanceType
}

model AttendanceTarget {
  uid    String @id @unique
  timeMs Int
}

model AttendanceLeaveRecord {
  id String @id @default(uuid())

  uid  String
  date DateTime @db.Date

  timeMs  Int
  summary String?

  @@unique([uid, date])
}

model OAuth {
  uid String @id

  githubAccessToken  String?
  googleRefreshToken String?
}
