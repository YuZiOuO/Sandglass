{
  "name": "@sandglass/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "run-p typecheck \"build-only {@}\" --",
    "build-only": "vite build",
    "check": "run-s typecheck lint format:check test build-only",
    "dev": "vite",
    "format": "prettier --write --experimental-cli src/",
    "format:check": "prettier --check --experimental-cli src/",
    "lint": "oxlint . && eslint . --cache",
    "lint:fix": "oxlint . --fix && eslint . --fix --cache",
    "lint:staged": "lint-staged",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --build"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "prettier --write --experimental-cli",
      "eslint --fix --cache",
      "oxlint --fix"
    ]
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@vicons/ionicons5": "^0.13.0",
    "naive-ui": "^2.44.1",
    "pinia": "^4.0.2",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@sandglass/api": "workspace:*",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.73.0",
    "eslint-plugin-vue": "~10.10.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "oxlint": "~1.74.0",
    "prettier": "3.9.6",
    "type-fest": "^5.8.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
