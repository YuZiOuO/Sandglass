// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgres"
}

generator zod {
  provider = "zod-prisma-types"
  output   = "../src/generated/zod"
}

model Project {
  id String @id @default(uuid())

  /// @zod.string.min(1)
  uid String

  /// @zod.string.min(1)
  calendarId String

  /// @zod.string.min(1)
  tasklistId String

  // 建议增加时间戳，PostgreSQL 开发的标配
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("projects") // 习惯上数据库表名用复数
}

enum AttendanceType {
  IN
  OUT
}

model AttendanceRecord {
  id String @id @default(uuid())

  uid String

  time DateTime

  type AttendanceType
}
